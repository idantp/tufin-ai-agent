# === Required: set these in .env ===

# OpenWeatherMap API key (get from: https://openweathermap.org/api)
OPENWEATHER_API_KEY=

# Tavily search API key (get from: https://tavily.com/)
TAVILY_API_KEY=

# === Optional: uncomment to override defaults ===

# SQLite database path (default: ./data/agent.db)
# DATABASE_URL=./data/agent.db

# Ollama model name (default: qwen2.5:7b-instruct-q4_K_M)
# OLLAMA_MODEL=qwen2.5:7b-instruct-q4_K_M

# Ollama server URL (default: http://localhost:11434)
# OLLAMA_BASE_URL=http://localhost:11434

# Maximum iterations for the agent loop (default: 10)
# AGENT_MAX_ITERATIONS=10

# Logging level: DEBUG, INFO, WARNING, ERROR, CRITICAL (default: INFO)
# LOG_LEVEL=INFO
